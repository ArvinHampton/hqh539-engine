# =====================================================
# HQH-539 Resonant Hash Engine — LIVE MODE TEMPLATE
# Copy to .env for local development only.
# On Streamlit Cloud, use Secrets instead (see deployment guide).
# =====================================================

# Stripe Live secret key (Dashboard → Developers → API keys → Live mode)
STRIPE_SECRET_KEY=sk_live_YOUR_LIVE_SECRET_KEY

# =====================================================
# Live Price IDs (Dashboard → Products → Prices)
# =====================================================

# HQH-539 Pro — $149/month subscription
STRIPE_PRICE_ID_PRO=price_1TlP5mCQLkwPXwCzmcI1Sc6k

# Credit packs (one-time)
STRIPE_PRICE_ID_100=price_1TlP5jCQLkwPXwCzWfyjh03A
STRIPE_PRICE_ID_500=price_1TlP5jCQLkwPXwCzW5ZNpn8F
STRIPE_PRICE_ID_2000=price_1TlP5iCQLkwPXwCztvca56EG

# Live webhook signing secret (after creating endpoint on your webhook host)
STRIPE_WEBHOOK_SECRET=whsec_YOUR_LIVE_WEBHOOK_SECRET

# Public URL of the Streamlit app (no trailing slash)
APP_URL=https://your-app-name.streamlit.app

# Writable directory for SQLite (use /tmp/hqh539 on Streamlit Cloud)
HQH539_DATA_DIR=.

# Shared database for Streamlit Cloud + local ngrok webhook (recommended)
# Free tier: https://neon.tech — paste connection string here
# DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require